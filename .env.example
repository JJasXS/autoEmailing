# Copy to .env and fill in. See Program.cs — DotNetEnv loads .env before the host starts.

# TENANT_CODE here (not in appsettings). TenantBootstrap API URL stays in appsettings.json.

TENANT_CODE=TNT10005
# TenantBootstrap__AwsApiKey=

# Send time (local) and time zone (not in appsettings by default).
# Daily (default): omit SendFrequency or set App__Schedule__SendFrequency=Daily
# Weekly same local time: App__Schedule__SendFrequency=Weekly and day name:
# App__Schedule__SendDayOfWeek=Monday
App__Schedule__SendTime=08:00
App__Schedule__TimeZone=Asia/Kuala_Lumpur
# App__Schedule__SendFrequency=Weekly
# App__Schedule__SendDayOfWeek=Monday

# Firebird: use appsettings.json → App:Firebird unless overridden with App__Firebird__* here.
# AWS Secrets Manager (when tenant DB uses dbPasswordSecretRef, or App:Smtp:SmtpPasswordSecretRef is set)
# Same as eQuotation: region + default credential chain (keys, profile, or IAM role on the machine).
# AWS_REGION=ap-southeast-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# Optional: AWS_SESSION_TOKEN=

App__Smtp__SmtpHost=smtp.gmail.com
App__Smtp__SmtpPort=587
App__Smtp__EnableSsl=true
App__Smtp__SmtpUser=
App__Smtp__SmtpPassword=
# Or use a secret name/ARN instead of inline password:
# App__Smtp__SmtpPasswordSecretRef=your-secret-id-or-arn
App__Smtp__FromEmail=
App__Smtp__FromName=SQL Accounting Notifications
