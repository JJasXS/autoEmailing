# Copy to .env next to the built exe (e.g. bin\Debug\net10.0\.env). Program loads cwd .env first, then that file — the exe folder wins so schedule is not overridden by a .env in another working directory.

# TENANT_CODE here (not in appsettings). TenantBootstrap API URL stays in appsettings.json.

TENANT_CODE=TNT10005
# TenantBootstrap__AwsApiKey=

# Send time: use a colon (HH:mm), e.g. 11:03 — not 11.03 (dot is invalid for .NET TimeOnly).
# Send time (wall clock in App__Schedule__TimeZone): next run is the next time that clock reads HH:mm (not a separate "daily job" name).
# Non-weekly: omit SendFrequency or set anything other than Weekly. Weekly: App__Schedule__SendFrequency=Weekly and day name:
# App__Schedule__SendDayOfWeek=Monday
App__Schedule__SendTime=08:00
App__Schedule__TimeZone=Asia/Kuala_Lumpur
# App__Schedule__SendFrequency=Weekly
# App__Schedule__SendDayOfWeek=Monday

# One-shot SY_USER (EMAIL + UDF_AEMAIL): dotnet run -- --sy-user-test-email
# Uses App:ScheduledTestEmail Subject/PlainBody from appsettings (or App__ScheduledTestEmail__* in .env).
# If App__ScheduledTestEmail__To is set, sends only there — leave empty to use SY_USER list.

# Firebird: use appsettings.json → App:Firebird unless overridden with App__Firebird__* here.
# AWS Secrets Manager (when tenant DB uses dbPasswordSecretRef, or App:Smtp:SmtpPasswordSecretRef is set)
# Same as eQuotation: region + default credential chain (keys, profile, or IAM role on the machine).
# AWS_REGION=ap-southeast-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# Optional: AWS_SESSION_TOKEN=

App__Smtp__SmtpHost=smtp.gmail.com
App__Smtp__SmtpPort=587
App__Smtp__EnableSsl=true
App__Smtp__SmtpUser=
App__Smtp__SmtpPassword=
# Or use a secret name/ARN instead of inline password:
# App__Smtp__SmtpPasswordSecretRef=your-secret-id-or-arn
App__Smtp__FromEmail=
App__Smtp__FromName=SQL Accounting Notifications

# SO preview HTTP (dotnet run / --preview-so): default binds loopback only. Using EC2 public DNS in the browser
# causes "400 Bad Request - Invalid Hostname" unless you allow any host:
# PREVIEW_SO_ANY_HOST=1
# On Windows, also run once (elevated): netsh http add urlacl url=http://+:2086/ user=Everyone
# PREVIEW_SO_PORT=2086

# Daily batch: Excel + PDF attachments (same Firebird SQL for all recipients). See EmailFormats/previewSO.html.
# App__DailyAttachmentReport__Enabled=true
# App__DailyAttachmentReport__CurrencyLabel=MYR
# App__DailyAttachmentReport__ReportTitle=Outstanding summary
# App__DailyAttachmentReport__CompanyName=
# Sql is easiest in appsettings.json (multi-line). To force from env, use a single line or multiple App__ keys per your hoster.

# SO transfer outstanding (SL_SO / ST_XTRANS): Excel + PDF on each scheduled batch. Default true in appsettings.json; set false to disable.
App__SoTransferOutstandingReport__Enabled=true
